# Copia este ficheiro para secrets.toml e preenche com as tuas credenciais.
# NUNCA faças commit de secrets.toml (já está no .gitignore).

# Opção 1: Cola o JSON completo da conta de serviço (recomendado).
# Obtém o ficheiro em: Google Cloud Console → IAM → Contas de serviço → Criar chave JSON
# Substitui o texto entre as aspas triplas pelo conteúdo do ficheiro JSON.
google_credentials_json = """
{
  "type": "service_account",
  "project_id": "o-teu-projeto",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",
  "client_email": "xxx@yyy.iam.gserviceaccount.com",
  "client_id": "...",
  ...
}
"""

# Opção 2: Em alternativa, podes definir cada campo em [google_credentials]
# [google_credentials]
# type = "service_account"
# project_id = "o-teu-projeto"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
# client_email = "xxx@yyy.iam.gserviceaccount.com"
# client_id = "..."
